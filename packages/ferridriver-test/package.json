{
  "name": "@ferridriver/test",
  "version": "0.1.0",
  "description": "E2E, BDD, and component test runner for Node and Bun. Playwright-compatible API, Rust engine.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "MIT OR Apache-2.0",
  "author": "Salama Ashoush <salamaashoush@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/salamaashoush/ferridriver",
    "directory": "packages/ferridriver-test"
  },
  "homepage": "https://github.com/salamaashoush/ferridriver",
  "bugs": {
    "url": "https://github.com/salamaashoush/ferridriver/issues"
  },
  "keywords": [
    "ferridriver",
    "testing",
    "e2e",
    "component-testing",
    "playwright"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./bdd": "./src/bdd.ts"
  },
  "bin": {
    "ferridriver-test": "dist/cli.js"
  },
  "scripts": {
    "build:cli": "bun build src/cli.ts --target=node --outdir=dist --external @ferridriver/node --external @ferridriver/ct-core --external clap-ts --external jiti --external ./test.js --external ./config.js --external ./bdd.js --external ./expect.js --external '*.node'"
  },
  "dependencies": {
    "@ferridriver/node": "workspace:*",
    "@ferridriver/ct-core": "workspace:*",
    "clap-ts": "^0.2.1",
    "jiti": "^2.6.1"
  }
}
