{
  "name": "@ferridriver/node",
  "version": "0.2.0",
  "description": "High-performance browser automation library with Playwright-compatible API",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "author": "Salama Ashoush <salamaashoush@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/salamaashoush/ferridriver"
  },
  "homepage": "https://github.com/salamaashoush/ferridriver",
  "bugs": {
    "url": "https://github.com/salamaashoush/ferridriver/issues"
  },
  "keywords": [
    "napi-rs",
    "browser",
    "automation",
    "playwright",
    "cdp",
    "webkit",
    "rust"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "fd_webkit_host",
    "postinstall.js"
  ],
  "napi": {
    "binaryName": "ferridriver-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "optionalDependencies": {
    "@ferridriver/node-darwin-x64": "0.2.0",
    "@ferridriver/node-darwin-arm64": "0.2.0",
    "@ferridriver/node-linux-x64-gnu": "0.2.0",
    "@ferridriver/node-linux-arm64-gnu": "0.2.0",
    "@ferridriver/node-win32-x64-msvc": "0.2.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "postinstall": "node postinstall.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0"
  }
}
